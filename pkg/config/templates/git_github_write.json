{
  "repos": ["OWNER/REPO"],
  "repo_paths": ["/path/to/repo"],
  "allowed_operations": [
    "git_fetch",
    "git_push",
    "gh_pr_view",
    "gh_pr_list",
    "gh_pr_checks",
    "gh_pr_review_comments",
    "gh_pr_create",
    "gh_pr_edit",
    "gh_pr_comment",
    "gh_pr_review_comment_reply",
    "gh_issue_view",
    "gh_issue_list",
    "gh_run_view"
  ],
  "constraints": {
    "remote_hosts_allow": ["github.com"]
  },
  "operations": {
    "git_fetch": {
      "command": "git",
      "args_template": ["fetch", "origin"],
      "params": {},
      "description": "Fetch from origin remote"
    },
    "git_push": {
      "command": "git",
      "args_template": ["push", "--no-verify", "{expected_git_url}", "{branch}:refs/heads/{branch}"],
      "params": {
        "branch": {"type": "string", "pattern": "^[a-zA-Z0-9._/-]+$", "minLength": 1, "maxLength": 255}
      },
      "description": "Push branch to the daemon-resolved expected URL of target_repo (strict sanitization + explicit URL fixation)"
    },
    "gh_pr_view": {
      "command": "gh",
      "args_template": ["pr", "view", "{number}", "-R", "{repo}"],
      "params": {
        "number": {"type": "integer", "min": 1}
      },
      "allowed_flags": ["--json", "--comments"],
      "bool_flags": ["--comments"],
      "description": "View a pull request"
    },
    "gh_pr_list": {
      "command": "gh",
      "args_template": ["pr", "list", "-R", "{repo}"],
      "params": {},
      "allowed_flags": ["--json", "--state", "--limit", "--author", "--label", "--base", "--head"],
      "description": "List pull requests"
    },
    "gh_pr_checks": {
      "command": "gh",
      "args_template": ["pr", "checks", "{number}", "-R", "{repo}"],
      "params": {
        "number": {"type": "integer", "min": 1}
      },
      "allowed_flags": ["--json", "--required"],
      "bool_flags": ["--required"],
      "description": "Show CI check status for a pull request"
    },
    "gh_pr_review_comments": {
      "command": "gh",
      "args_template": ["api", "repos/{repo}/pulls/{number}/comments"],
      "params": {
        "number": {"type": "integer", "min": 1}
      },
      "allowed_flags": ["--paginate", "--jq"],
      "bool_flags": ["--paginate"],
      "description": "List inline pull request review comments"
    },
    "gh_pr_create": {
      "command": "gh",
      "args_template": ["pr", "create", "-R", "{repo}", "--body", "{body}"],
      "params": {
        "body": {"type": "string", "minLength": 1, "maxLength": 65535, "pattern": "\\S"}
      },
      "allowed_flags": ["--title", "--base", "--head", "--draft", "--label", "--assignee", "--reviewer"],
      "bool_flags": ["--draft"],
      "description": "Create a pull request"
    },
    "gh_pr_edit": {
      "command": "gh",
      "args_template": ["pr", "edit", "{number}", "-R", "{repo}", "--body", "{body}"],
      "params": {
        "number": {"type": "integer", "min": 1},
        "body": {"type": "string", "optional": true, "maxLength": 65535}
      },
      "allowed_flags": ["--title", "--add-label", "--remove-label", "--add-assignee", "--remove-assignee"],
      "description": "Edit a pull request (title, body, labels, assignees)"
    },
    "gh_pr_comment": {
      "command": "gh",
      "args_template": ["pr", "comment", "{number}", "-R", "{repo}", "--body", "{body}"],
      "params": {
        "number": {"type": "integer", "min": 1},
        "body": {"type": "string", "minLength": 1, "maxLength": 65535, "pattern": "\\S"}
      },
      "description": "Add a pull request summary comment"
    },
    "gh_pr_review_comment_reply": {
      "command": "gh",
      "args_template": ["api", "-X", "POST", "repos/{repo}/pulls/{number}/comments/{comment_id}/replies", "-f", "body={body}"],
      "params": {
        "number": {"type": "integer", "min": 1},
        "comment_id": {"type": "integer", "min": 1},
        "body": {"type": "string", "minLength": 1, "maxLength": 65535, "pattern": "\\S"}
      },
      "description": "Reply to an inline pull request review comment"
    },
    "gh_issue_view": {
      "command": "gh",
      "args_template": ["issue", "view", "{number}", "-R", "{repo}"],
      "params": {
        "number": {"type": "integer", "min": 1}
      },
      "allowed_flags": ["--json", "--comments"],
      "bool_flags": ["--comments"],
      "description": "View an issue"
    },
    "gh_issue_list": {
      "command": "gh",
      "args_template": ["issue", "list", "-R", "{repo}"],
      "params": {},
      "allowed_flags": ["--json", "--state", "--limit", "--author", "--label", "--assignee"],
      "description": "List issues"
    },
    "gh_run_view": {
      "command": "gh",
      "args_template": ["run", "view", "{run_id}", "-R", "{repo}"],
      "params": {
        "run_id": {"type": "integer", "min": 1}
      },
      "allowed_flags": ["--json", "--log", "--log-failed", "--exit-status", "--job"],
      "bool_flags": ["--log", "--log-failed", "--exit-status"],
      "description": "View a workflow run (supports --log / --log-failed)"
    }
  }
}
